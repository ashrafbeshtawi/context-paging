# === Provider Configuration ===

# Choose your LLM provider (default: anthropic)
# Options: anthropic | openai | google | mistral | xai | amazon-bedrock | azure
AI_PROVIDER=anthropic

# Choose your model (default: depends on provider)
# Anthropic:      claude-sonnet-4-20250514, claude-opus-4-20250514, claude-haiku-4-5-20251001
# OpenAI:         gpt-4o, gpt-4o-mini, o1, o1-mini
# Google:         gemini-2.0-flash, gemini-2.5-pro
# Mistral:        mistral-large-latest, mistral-small-latest
# xAI:            grok-3, grok-3-mini
AI_MODEL=claude-sonnet-4-20250514

# === API Keys (set the one matching your provider) ===
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
MISTRAL_API_KEY=
XAI_API_KEY=
AZURE_API_KEY=

# === Storage ===
# Directory for page storage (default: ./pages)
# PAGES_ROOT=./pages

# === Debug ===
# Enable debug mode to see context window stats and tool call details
# DEBUG=true
